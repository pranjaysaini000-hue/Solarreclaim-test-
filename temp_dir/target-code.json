[{"id":10451,"slug":"renewable-energy-90","title":"Renewable Energy Services Landing Page Template","code":"<!DOCTYPE html>\n<html lang=\"en\" class=\"scroll-smooth\">\n<head>\n<script>\ntry{if(window.parent&&window.parent!==window){window.parent.promotekit_referral=\"1fd2949a-d22c-431b-92bf-02d4ad04ee24\";window.parent.document.cookie=\"promotekit_referral=1fd2949a-d22c-431b-92bf-02d4ad04ee24;path=/;domain=.aura.build;max-age=31536000\"}}catch(e){}\n</script>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>PikaG Energy | The Future of Generation</title>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<script src=\"https://unpkg.com/lucide@latest\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n<style>\nbody {\nfont-family: 'Plus Jakarta Sans', sans-serif;\nbackground-color: #ffffff;\ncolor: #0a0a0a;\noverflow-x: hidden;\n}\n/* Smooth Reveal Animation */\n.reveal {\nopacity: 0;\ntransform: translateY(30px);\ntransition: all 1s cubic-bezier(0.16, 1, 0.3, 1);\n}\n.reveal.active {\nopacity: 1;\ntransform: translateY(0);\n}\n.reveal-delay-1 { transition-delay: 100ms; }\n.reveal-delay-2 { transition-delay: 200ms; }\n.reveal-delay-3 { transition-delay: 300ms; }\n/* Glassmorphism Navigation */\n.glass-nav {\nbackground: rgba(255, 255, 255, 0.9);\nbackdrop-filter: blur(16px);\n-webkit-backdrop-filter: blur(16px);\nborder-bottom: 1px solid rgba(0, 0, 0, 0.05);\n}\n/* Hero Carousel Transitions */\n.slide {\ntransition: opacity 1.5s ease-in-out, transform 8s ease-out;\n}\n.slide.active {\nopacity: 1;\ntransform: scale(1.05);\n}\n.slide.inactive {\nopacity: 0;\ntransform: scale(1);\n}\n/* Custom Scrollbar */\n::-webkit-scrollbar { width: 6px; }\n::-webkit-scrollbar-track { background: #fafafa; }\n::-webkit-scrollbar-thumb { background: #16a34a; border-radius: 4px; }\n/* Accordion Animation */\ndetails > summary { list-style: none; }\ndetails > summary::-webkit-details-marker { display: none; }\ndetails[open] summary ~ * {\nanimation: sweep .3s ease-in-out;\n}\n@keyframes sweep {\n0%    {opacity: 0; transform: translateY(-10px)}\n100%  {opacity: 1; transform: translateY(0)}\n}\n</style></head>\n<body class=\"antialiased selection:bg-green-500 selection:text-white\">\n\n    <!-- Navigation -->\n    <nav class=\"fixed top-0 w-full z-50 glass-nav transition-all duration-300\">\n        <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\">\n            <a href=\"#\" class=\"flex items-center gap-2 group\">\n                <div class=\"w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center text-white shadow-lg shadow-green-500/20 group-hover:scale-105 transition-transform duration-300\">\n                    <i data-lucide=\"zap\" class=\"w-4 h-4 fill-current\"></i>\n                </div>\n                <span class=\"text-lg font-bold tracking-tight text-neutral-900\">PikaG</span>\n            </a>\n\n            <div class=\"hidden md:flex items-center space-x-10 text-sm font-medium text-neutral-500\">\n                <a href=\"#home\" class=\"text-neutral-900 hover:text-green-600 transition-colors\">Home</a>\n                <a href=\"#technology\" class=\"hover:text-green-600 transition-colors\">Technology</a>\n                <a href=\"#products\" class=\"hover:text-green-600 transition-colors\">Products</a>\n                <a href=\"#about\" class=\"hover:text-green-600 transition-colors\">About</a>\n            </div>\n\n            <div class=\"flex items-center gap-4\">\n                <a href=\"#contact\" class=\"hidden md:flex px-5 py-2.5 rounded-full bg-neutral-900 text-white text-xs font-semibold hover:bg-green-600 hover:shadow-lg hover:shadow-green-500/25 transition-all duration-300 items-center gap-2\">\n                    Get in touch\n                </a>\n                <button class=\"md:hidden text-neutral-900\">\n                    <i data-lucide=\"menu\" class=\"w-6 h-6\"></i>\n                </button>\n            </div>\n        </div>\n    </nav>\n\n    <!-- Full Width Hero Section with Carousel -->\n    <section id=\"home\" class=\"relative w-full h-screen overflow-hidden bg-neutral-900\">\n        \n        <!-- Slider Images -->\n        <div id=\"hero-slider\" class=\"absolute inset-0 w-full h-full\">\n            <!-- Slide 1 -->\n            <div class=\"slide active absolute inset-0 w-full h-full\">\n                <div class=\"absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/80 z-10\"></div>\n                <img src=\"https://images.unsplash.com/photo-1509391366360-2e959784a276?q=80&w=2672&auto=format&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Solar Farm\">\n            </div>\n            <!-- Slide 2 -->\n            <div class=\"slide inactive absolute inset-0 w-full h-full\">\n                <div class=\"absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/80 z-10\"></div>\n                <img src=\"https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?q=80&w=2670&auto=format&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Industrial Grid\">\n            </div>\n            <!-- Slide 3 -->\n            <div class=\"slide inactive absolute inset-0 w-full h-full\">\n                <div class=\"absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/80 z-10\"></div>\n                <img src=\"https://images.unsplash.com/photo-1497436072909-60f360e1d4b0?q=80&w=2560&auto=format&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Smart City\">\n            </div>\n        </div>\n\n        <!-- Content Overlay -->\n        <div class=\"absolute inset-0 z-20 flex flex-col items-center justify-center px-6 text-center\">\n            <div class=\"reveal max-w-4xl mx-auto\">\n                <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-green-400 text-[10px] font-bold uppercase tracking-widest mb-8 shadow-sm\">\n                    <span class=\"w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse\"></span>\n                    <span id=\"slide-tag\">Sustainable Solar Ecosystems</span>\n                </div>\n                \n                <h1 id=\"slide-title\" class=\"text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white leading-[1.05] mb-8 transition-all duration-500\">\n                    Powering the <br>Next Generation.\n                </h1>\n                \n                <p id=\"slide-desc\" class=\"text-lg md:text-xl text-neutral-300 font-light leading-relaxed mb-10 max-w-2xl mx-auto transition-all duration-500\">\n                    Designing the infrastructure for a cleaner planet. From industrial solar arrays to smart city integration.\n                </p>\n\n                <div class=\"flex flex-col sm:flex-row gap-4 justify-center\">\n                    <a href=\"#products\" class=\"px-8 py-4 bg-white text-neutral-900 rounded-full text-sm font-bold hover:bg-green-500 hover:text-white transition-all duration-300 flex items-center justify-center gap-2 shadow-xl shadow-white/5\">\n                        Explore Solutions\n                        <i data-lucide=\"arrow-right\" class=\"w-4 h-4\"></i>\n                    </a>\n                    <a href=\"#contact\" class=\"px-8 py-4 bg-white/10 backdrop-blur-md text-white border border-white/20 rounded-full text-sm font-bold hover:bg-white/20 transition-all duration-300\">\n                        Speak to Sales\n                    </a>\n                </div>\n            </div>\n        </div>\n\n        <!-- Slider Indicators -->\n        <div class=\"absolute bottom-10 left-1/2 -translate-x-1/2 z-30 flex gap-3\">\n            <button onclick=\"changeSlide(0)\" class=\"w-12 h-1 rounded-full bg-white transition-all duration-300 hover:bg-green-500 slider-dot\"></button>\n            <button onclick=\"changeSlide(1)\" class=\"w-12 h-1 rounded-full bg-white/30 transition-all duration-300 hover:bg-green-500 slider-dot\"></button>\n            <button onclick=\"changeSlide(2)\" class=\"w-12 h-1 rounded-full bg-white/30 transition-all duration-300 hover:bg-green-500 slider-dot\"></button>\n        </div>\n    </section>\n\n    <!-- Clients Section -->\n    <section class=\"py-12 bg-white border-b border-neutral-100\">\n        <div class=\"max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-8\">\n            <p class=\"text-xs font-bold text-neutral-400 uppercase tracking-widest whitespace-nowrap\">Trusted by industry leaders</p>\n            <div class=\"flex flex-wrap justify-center md:justify-end items-center gap-8 md:gap-16 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-500 w-full\">\n                <h3 class=\"text-xl font-bold text-neutral-800 tracking-tight\">NOVA</h3>\n                <h3 class=\"text-xl font-bold text-neutral-800 tracking-tight\">PWD</h3>\n                <div class=\"flex flex-col items-center\">\n                    <span class=\"text-lg font-bold text-neutral-800 leading-none\">RDA</span>\n                </div>\n                <div class=\"flex items-center gap-2\">\n                    <i data-lucide=\"train-track\" class=\"w-6 h-6 text-neutral-800\"></i>\n                    <span class=\"text-lg font-bold text-neutral-800\">Indian Railways</span>\n                </div>\n                <h3 class=\"text-xl font-bold text-neutral-800 tracking-tight\">CREDA</h3>\n            </div>\n        </div>\n    </section>\n\n    <!-- New: Core Technology Bento Grid -->\n    <section id=\"technology\" class=\"py-24 bg-neutral-50\">\n        <div class=\"max-w-7xl mx-auto px-6\">\n            <div class=\"mb-16 reveal\">\n                <span class=\"text-green-600 font-bold tracking-widest text-xs uppercase mb-2 block\">Core Architecture</span>\n                <h2 class=\"text-4xl md:text-5xl font-bold text-neutral-900 tracking-tight\">Engineered for Efficiency.</h2>\n                <p class=\"text-neutral-500 mt-4 max-w-2xl text-lg font-light\">Our proprietary technology stack integrates hardware and software to deliver maximum yield.</p>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n                <!-- Large Card -->\n                <div class=\"reveal md:col-span-2 bg-white p-8 rounded-3xl border border-neutral-200 shadow-sm hover:shadow-md transition-all duration-300 relative overflow-hidden group\">\n                    <div class=\"absolute right-0 top-0 w-64 h-64 bg-green-50 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 group-hover:bg-green-100 transition-colors\"></div>\n                    <div class=\"relative z-10\">\n                        <div class=\"w-12 h-12 bg-green-100 text-green-600 rounded-xl flex items-center justify-center mb-6\">\n                            <i data-lucide=\"cpu\" class=\"w-6 h-6\"></i>\n                        </div>\n                        <h3 class=\"text-2xl font-bold text-neutral-900 mb-3\">Intelligent Load Balancing</h3>\n                        <p class=\"text-neutral-500 leading-relaxed max-w-md\">Our AI-driven PCB units automatically distribute power loads across the grid, preventing surges and optimizing battery life by up to 40% compared to traditional inverters.</p>\n                        <div class=\"mt-8 flex items-center gap-4 text-sm font-medium text-neutral-900\">\n                            <div class=\"flex items-center gap-2\"><i data-lucide=\"check-circle-2\" class=\"w-4 h-4 text-green-500\"></i> 99.9% Uptime</div>\n                            <div class=\"flex items-center gap-2\"><i data-lucide=\"check-circle-2\" class=\"w-4 h-4 text-green-500\"></i> Real-time Analytics</div>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Tall Card -->\n                <div class=\"reveal md:row-span-2 bg-neutral-900 p-8 rounded-3xl border border-neutral-800 text-white relative overflow-hidden group\">\n                    <div class=\"absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-20\"></div>\n                    <div class=\"absolute bottom-0 right-0 w-full h-1/2 bg-gradient-to-t from-green-900/40 to-transparent\"></div>\n                    <div class=\"relative z-10 h-full flex flex-col justify-between\">\n                        <div>\n                            <div class=\"w-12 h-12 bg-white/10 text-white rounded-xl flex items-center justify-center mb-6 border border-white/10\">\n                                <i data-lucide=\"shield-check\" class=\"w-6 h-6\"></i>\n                            </div>\n                            <h3 class=\"text-2xl font-bold mb-3\">Military Grade Durability</h3>\n                            <p class=\"text-neutral-400 leading-relaxed text-sm\">Hardware designed to withstand extreme weather conditions, from desert heat to coastal storms.</p>\n                        </div>\n                        <div class=\"mt-8\">\n                            <div class=\"text-5xl font-bold tracking-tight text-green-400 mb-1\">25<span class=\"text-2xl text-white\">yr</span></div>\n                            <p class=\"text-neutral-400 text-xs uppercase tracking-wider\">Warranty Guarantee</p>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Small Card 1 -->\n                <div class=\"reveal reveal-delay-1 bg-white p-8 rounded-3xl border border-neutral-200 shadow-sm hover:shadow-md transition-all duration-300\">\n                    <i data-lucide=\"zap\" class=\"w-10 h-10 text-neutral-900 mb-4\"></i>\n                    <h3 class=\"text-lg font-bold text-neutral-900 mb-2\">High Voltage Tech</h3>\n                    <p class=\"text-sm text-neutral-500\">Advanced 1500V systems reducing BOS costs significantly.</p>\n                </div>\n\n                <!-- Small Card 2 -->\n                <div class=\"reveal reveal-delay-2 bg-white p-8 rounded-3xl border border-neutral-200 shadow-sm hover:shadow-md transition-all duration-300\">\n                    <i data-lucide=\"signal\" class=\"w-10 h-10 text-neutral-900 mb-4\"></i>\n                    <h3 class=\"text-lg font-bold text-neutral-900 mb-2\">IoT Connectivity</h3>\n                    <p class=\"text-sm text-neutral-500\">Monitor your entire grid from a single smartphone dashboard.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Services/Products Section -->\n    <section id=\"products\" class=\"py-24 bg-white relative overflow-hidden\">\n        <div class=\"max-w-7xl mx-auto px-6\">\n            <div class=\"flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6 reveal\">\n                <div>\n                    <span class=\"text-green-600 font-bold tracking-widest text-xs uppercase mb-2 block\">Our Services</span>\n                    <h2 class=\"text-4xl md:text-5xl font-bold text-neutral-900 tracking-tight\">Premium Industry Solutions</h2>\n                    <p class=\"text-neutral-500 mt-4 max-w-xl font-light\">Delivering world-class technological solutions from renowned manufacturers.</p>\n                </div>\n                <a href=\"#contact\" class=\"px-6 py-3 rounded-full border border-neutral-200 hover:bg-neutral-900 hover:text-white transition-all duration-300 text-sm font-semibold\">\n                    Get Custom Quote\n                </a>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n                <!-- Product Card 1 -->\n                <div class=\"reveal group relative p-8 rounded-3xl bg-neutral-50 border border-neutral-100 hover:border-green-200 hover:shadow-lg hover:shadow-green-500/5 transition-all duration-300\">\n                    <div class=\"w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-green-600 mb-6 group-hover:scale-110 transition-transform\">\n                        <i data-lucide=\"factory\" class=\"w-6 h-6\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold mb-3 text-neutral-900\">Industrial Machinery</h3>\n                    <p class=\"text-neutral-500 text-sm leading-relaxed mb-6\">High-performance industrial equipment from leading manufacturers, optimized for efficiency and reliability.</p>\n                    <a href=\"#\" class=\"text-green-600 text-sm font-bold flex items-center gap-2 group-hover:gap-3 transition-all\">Learn more <i data-lucide=\"arrow-right\" class=\"w-4 h-4\"></i></a>\n                </div>\n\n                <!-- Product Card 2 -->\n                <div class=\"reveal reveal-delay-1 group relative p-8 rounded-3xl bg-neutral-50 border border-neutral-100 hover:border-green-200 hover:shadow-lg hover:shadow-green-500/5 transition-all duration-300\">\n                    <div class=\"w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-green-600 mb-6 group-hover:scale-110 transition-transform\">\n                        <i data-lucide=\"bot\" class=\"w-6 h-6\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold mb-3 text-neutral-900\">Robotics & Automation</h3>\n                    <p class=\"text-neutral-500 text-sm leading-relaxed mb-6\">Cutting-edge robotics solutions to streamline operations, increase productivity, and reduce operational costs.</p>\n                    <a href=\"#\" class=\"text-green-600 text-sm font-bold flex items-center gap-2 group-hover:gap-3 transition-all\">Learn more <i data-lucide=\"arrow-right\" class=\"w-4 h-4\"></i></a>\n                </div>\n\n                <!-- Product Card 3 -->\n                <div class=\"reveal reveal-delay-2 group relative p-8 rounded-3xl bg-neutral-50 border border-neutral-100 hover:border-green-200 hover:shadow-lg hover:shadow-green-500/5 transition-all duration-300\">\n                    <div class=\"w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-green-600 mb-6 group-hover:scale-110 transition-transform\">\n                        <i data-lucide=\"sun\" class=\"w-6 h-6\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold mb-3 text-neutral-900\">Solar Solutions</h3>\n                    <p class=\"text-neutral-500 text-sm leading-relaxed mb-6\">Industry-leading solar panel systems that deliver sustainable energy and significant cost savings.</p>\n                    <a href=\"#\" class=\"text-green-600 text-sm font-bold flex items-center gap-2 group-hover:gap-3 transition-all\">Learn more <i data-lucide=\"arrow-right\" class=\"w-4 h-4\"></i></a>\n                </div>\n                \n                 <!-- Product Card 4 -->\n                 <div class=\"reveal group relative p-8 rounded-3xl bg-neutral-50 border border-neutral-100 hover:border-green-200 hover:shadow-lg hover:shadow-green-500/5 transition-all duration-300\">\n                    <div class=\"w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-green-600 mb-6 group-hover:scale-110 transition-transform\">\n                        <i data-lucide=\"activity\" class=\"w-6 h-6\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold mb-3 text-neutral-900\">Drives & Controls</h3>\n                    <p class=\"text-neutral-500 text-sm leading-relaxed mb-6\">Precision motor drives for complex industrial applications requiring exact torque and speed management.</p>\n                    <a href=\"#\" class=\"text-green-600 text-sm font-bold flex items-center gap-2 group-hover:gap-3 transition-all\">Learn more <i data-lucide=\"arrow-right\" class=\"w-4 h-4\"></i></a>\n                </div>\n\n                 <!-- Product Card 5 -->\n                 <div class=\"reveal reveal-delay-1 group relative p-8 rounded-3xl bg-neutral-50 border border-neutral-100 hover:border-green-200 hover:shadow-lg hover:shadow-green-500/5 transition-all duration-300\">\n                    <div class=\"w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-green-600 mb-6 group-hover:scale-110 transition-transform\">\n                        <i data-lucide=\"wifi\" class=\"w-6 h-6\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold mb-3 text-neutral-900\">Smart IoT Modules</h3>\n                    <p class=\"text-neutral-500 text-sm leading-relaxed mb-6\">Connected sensors and communication gateways for smart city and industrial internet of things (IIoT).</p>\n                    <a href=\"#\" class=\"text-green-600 text-sm font-bold flex items-center gap-2 group-hover:gap-3 transition-all\">Learn more <i data-lucide=\"arrow-right\" class=\"w-4 h-4\"></i></a>\n                </div>\n\n                 <!-- Product Card 6 -->\n                 <div class=\"reveal reveal-delay-2 group relative p-8 rounded-3xl bg-neutral-50 border border-neutral-100 hover:border-green-200 hover:shadow-lg hover:shadow-green-500/5 transition-all duration-300\">\n                    <div class=\"w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-green-600 mb-6 group-hover:scale-110 transition-transform\">\n                        <i data-lucide=\"battery-charging\" class=\"w-6 h-6\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold mb-3 text-neutral-900\">Energy Storage</h3>\n                    <p class=\"text-neutral-500 text-sm leading-relaxed mb-6\">Lithium-ion commercial storage banks to ensure power availability during grid outages and peak times.</p>\n                    <a href=\"#\" class=\"text-green-600 text-sm font-bold flex items-center gap-2 group-hover:gap-3 transition-all\">Learn more <i data-lucide=\"arrow-right\" class=\"w-4 h-4\"></i></a>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- New: Feature Highlight / Global Reach -->\n    <section class=\"py-24 bg-neutral-900 text-white relative overflow-hidden\">\n        <!-- Abstract World Map Dots Background -->\n        <div class=\"absolute inset-0 opacity-10 bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:20px_20px]\"></div>\n        \n        <div class=\"max-w-7xl mx-auto px-6 relative z-10 grid lg:grid-cols-2 gap-16 items-center\">\n            <div class=\"reveal\">\n                <span class=\"text-green-400 font-bold tracking-widest text-xs uppercase mb-2 block\">Global Impact</span>\n                <h2 class=\"text-4xl md:text-5xl font-bold mb-6 tracking-tight\">Powering communities across the map.</h2>\n                <p class=\"text-neutral-400 text-lg leading-relaxed mb-8\">\n                    Our reach extends beyond borders. With projects implemented in diverse climates and regulatory environments, PikaG Energy is setting the standard for universal renewable adoption.\n                </p>\n                \n                <div class=\"grid grid-cols-2 gap-8 mb-8\">\n                    <div>\n                        <div class=\"text-3xl font-bold text-white mb-1\">45+</div>\n                        <div class=\"text-sm text-neutral-500\">Cities Electrified</div>\n                    </div>\n                    <div>\n                        <div class=\"text-3xl font-bold text-white mb-1\">12GW</div>\n                        <div class=\"text-sm text-neutral-500\">Power Generated</div>\n                    </div>\n                </div>\n\n                <a href=\"#about\" class=\"inline-flex items-center text-green-400 font-bold hover:text-green-300 transition-colors\">\n                    View Project Map <i data-lucide=\"arrow-right\" class=\"ml-2 w-4 h-4\"></i>\n                </a>\n            </div>\n\n            <div class=\"reveal reveal-delay-2 relative\">\n                <div class=\"relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl bg-neutral-800\">\n                    <div class=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-green-500 to-emerald-300\"></div>\n                    <div class=\"p-8\">\n                        <div class=\"flex items-center gap-4 mb-6\">\n                            <div class=\"w-10 h-10 rounded-full bg-green-500/20 flex items-center justify-center text-green-500\">\n                                <i data-lucide=\"globe-2\" class=\"w-5 h-5\"></i>\n                            </div>\n                            <div>\n                                <h4 class=\"font-bold text-lg\">Case Study: Smart Grid Alpha</h4>\n                                <p class=\"text-xs text-neutral-400\">Deployed: March 2023</p>\n                            </div>\n                        </div>\n                        <p class=\"text-neutral-300 text-sm mb-6 leading-relaxed\">\n                            Complete solar integration for a 500-unit industrial complex. Achieved 100% off-grid capability during daylight hours and reduced carbon footprint by 8,000 tons annually.\n                        </p>\n                        <div class=\"w-full bg-neutral-700 h-2 rounded-full mb-2 overflow-hidden\">\n                            <div class=\"bg-green-500 h-full w-[92%]\"></div>\n                        </div>\n                        <div class=\"flex justify-between text-xs text-neutral-400\">\n                            <span>Efficiency Target</span>\n                            <span class=\"text-white\">92% Achieved</span>\n                        </div>\n                    </div>\n                </div>\n                <!-- Decorative Elements -->\n                <div class=\"absolute -bottom-6 -right-6 w-24 h-24 bg-green-600 rounded-full blur-3xl opacity-20\"></div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Journey Section -->\n    <section id=\"about\" class=\"py-24 bg-white relative overflow-hidden\">\n        <div class=\"max-w-7xl mx-auto px-6\">\n            <div class=\"grid md:grid-cols-2 gap-16 items-start\">\n                <div class=\"reveal sticky top-32\">\n                    <span class=\"text-green-600 font-bold tracking-widest text-xs uppercase mb-2 block\">Our History</span>\n                    <h2 class=\"text-4xl md:text-5xl font-bold text-neutral-900 tracking-tight mb-6\">Milestones that define our legacy.</h2>\n                    <p class=\"text-neutral-500 leading-relaxed mb-8\">\n                        From a greenfield market to an industrial powerhouse, our path has been defined by innovation and a relentless pursuit of sustainable energy solutions.\n                    </p>\n                    <a href=\"#contact\" class=\"text-neutral-900 font-semibold border-b border-neutral-300 hover:border-green-600 pb-1 inline-flex items-center gap-2 transition-all\">\n                        Start your journey with us <i data-lucide=\"arrow-right\" class=\"w-4 h-4\"></i>\n                    </a>\n                </div>\n\n                <div class=\"relative pl-8 border-l border-neutral-200 space-y-16\">\n                    <!-- Chapter 1 -->\n                    <div class=\"reveal relative group\">\n                        <span class=\"absolute -left-[41px] top-1 w-5 h-5 rounded-full bg-white border-4 border-neutral-200 group-hover:border-green-500 transition-colors\"></span>\n                        <div class=\"bg-neutral-50 p-8 rounded-2xl border border-neutral-100 group-hover:shadow-xl transition-all duration-300\">\n                            <span class=\"text-6xl font-bold text-neutral-200 absolute top-4 right-4 select-none opacity-50\">01</span>\n                            <h3 class=\"text-xl font-bold text-neutral-900 mb-2 relative z-10\">Chapter 1</h3>\n                            <p class=\"text-green-600 font-medium text-sm mb-3\">Inception</p>\n                            <p class=\"text-neutral-500 text-sm\">India, a greenfield market. Identifying the gap in sustainable infrastructure and laying the foundation for clean energy adoption.</p>\n                        </div>\n                    </div>\n\n                    <!-- Chapter 2 -->\n                    <div class=\"reveal relative group\">\n                        <span class=\"absolute -left-[41px] top-1 w-5 h-5 rounded-full bg-white border-4 border-neutral-200 group-hover:border-green-500 transition-colors\"></span>\n                        <div class=\"bg-neutral-50 p-8 rounded-2xl border border-neutral-100 group-hover:shadow-xl transition-all duration-300\">\n                             <span class=\"text-6xl font-bold text-neutral-200 absolute top-4 right-4 select-none opacity-50\">02</span>\n                            <h3 class=\"text-xl font-bold text-neutral-900 mb-2 relative z-10\">Chapter 2</h3>\n                            <p class=\"text-green-600 font-medium text-sm mb-3\">Expansion</p>\n                            <p class=\"text-neutral-500 text-sm\">Driven by Demand. Scaling operations to meet the surging requirement for industrial-grade renewable components.</p>\n                        </div>\n                    </div>\n\n                    <!-- Chapter 3 -->\n                    <div class=\"reveal relative group\">\n                        <span class=\"absolute -left-[41px] top-1 w-5 h-5 rounded-full bg-white border-4 border-neutral-200 group-hover:border-green-500 transition-colors\"></span>\n                        <div class=\"bg-neutral-50 p-8 rounded-2xl border border-neutral-100 group-hover:shadow-xl transition-all duration-300\">\n                             <span class=\"text-6xl font-bold text-neutral-200 absolute top-4 right-4 select-none opacity-50\">03</span>\n                            <h3 class=\"text-xl font-bold text-neutral-900 mb-2 relative z-10\">Chapter 3</h3>\n                            <p class=\"text-green-600 font-medium text-sm mb-3\">Future Tech</p>\n                            <p class=\"text-neutral-500 text-sm\">Build your Telecom Empire. Integrating IoT and advanced PCB solutions for next-gen telecommunication networks.</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- FAQ Section -->\n    <section class=\"py-24 bg-neutral-50 border-t border-neutral-200\">\n        <div class=\"max-w-3xl mx-auto px-6\">\n            <h2 class=\"text-3xl font-bold text-neutral-900 mb-2 text-center reveal\">F.A.Q</h2>\n            <p class=\"text-neutral-500 text-center mb-12 text-sm reveal\">Common questions regarding our industrial solutions.</p>\n\n            <div class=\"space-y-4\">\n                <details class=\"reveal group bg-white p-5 rounded-xl border border-neutral-200 cursor-pointer shadow-sm\">\n                    <summary class=\"flex justify-between items-center font-medium text-neutral-900 select-none\">\n                        What renewable energy solutions does PikaG Energy offer?\n                        <span class=\"transition group-open:rotate-45 text-green-600\">\n                            <i data-lucide=\"plus\" class=\"w-4 h-4\"></i>\n                        </span>\n                    </summary>\n                    <div class=\"text-neutral-500 text-sm mt-4 leading-relaxed pl-1\">\n                        We offer a comprehensive range of solutions including Photovoltaic Solar Arrays, Industrial Wind Turbines, LED lighting systems, and custom Grid Storage solutions tailored for both commercial and industrial applications.\n                    </div>\n                </details>\n\n                <details class=\"reveal reveal-delay-1 group bg-white p-5 rounded-xl border border-neutral-200 cursor-pointer shadow-sm\">\n                    <summary class=\"flex justify-between items-center font-medium text-neutral-900 select-none\">\n                        How can I get a quote for a solar installation?\n                        <span class=\"transition group-open:rotate-45 text-green-600\">\n                            <i data-lucide=\"plus\" class=\"w-4 h-4\"></i>\n                        </span>\n                    </summary>\n                    <div class=\"text-neutral-500 text-sm mt-4 leading-relaxed pl-1\">\n                        Simply click the \"Get Custom Quote\" button or visit our Contact section. One of our engineers will assess your site requirements and energy consumption history to provide a detailed proposal.\n                    </div>\n                </details>\n\n                <details class=\"reveal reveal-delay-2 group bg-white p-5 rounded-xl border border-neutral-200 cursor-pointer shadow-sm\">\n                    <summary class=\"flex justify-between items-center font-medium text-neutral-900 select-none\">\n                        What are the benefits of switching to renewable energy?\n                        <span class=\"transition group-open:rotate-45 text-green-600\">\n                            <i data-lucide=\"plus\" class=\"w-4 h-4\"></i>\n                        </span>\n                    </summary>\n                    <div class=\"text-neutral-500 text-sm mt-4 leading-relaxed pl-1\">\n                        Switching to renewables significantly reduces operational costs, lowers your carbon footprint, ensures energy independence from grid fluctuations, and increases the property value of your infrastructure.\n                    </div>\n                </details>\n            </div>\n        </div>\n    </section>\n\n    <!-- CTA & Footer -->\n    <footer id=\"contact\" class=\"bg-neutral-900 pt-24 pb-12 text-white border-t border-white/10\">\n        <div class=\"max-w-7xl mx-auto px-6\">\n            \n            <!-- Main CTA -->\n            <div class=\"grid md:grid-cols-2 gap-12 mb-24 items-center border-b border-white/10 pb-24\">\n                <div class=\"reveal\">\n                    <h2 class=\"text-4xl font-bold mb-4\">Ready to get started?</h2>\n                    <p class=\"text-neutral-400\">Contact us today for a free consultation and take the first step towards a sustainable future.</p>\n                </div>\n                <div class=\"reveal reveal-delay-1 flex flex-col sm:flex-row gap-4 justify-end\">\n                    <button class=\"bg-green-600 text-white px-8 py-4 rounded-full font-bold hover:bg-green-500 transition-colors shadow-lg shadow-green-900/20\">\n                        Get in touch\n                    </button>\n                    <button class=\"bg-white/10 backdrop-blur-sm border border-white/10 text-white px-8 py-4 rounded-full font-bold hover:bg-white/20 transition-colors\">\n                        View Portfolio\n                    </button>\n                </div>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16\">\n                <!-- Brand & Newsletter -->\n                <div class=\"lg:col-span-1 space-y-6\">\n                    <a href=\"#\" class=\"flex items-center gap-2\">\n                        <div class=\"w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center text-white\">\n                            <i data-lucide=\"zap\" class=\"w-4 h-4 fill-current\"></i>\n                        </div>\n                        <span class=\"text-xl font-bold tracking-tight text-white\">PikaG</span>\n                    </a>\n                    <div class=\"bg-white/5 p-6 rounded-2xl border border-white/10\">\n                        <p class=\"text-xs text-neutral-400 font-bold uppercase tracking-widest mb-4\">Newsletter</p>\n                        <p class=\"text-sm text-neutral-300 mb-4\">Keep up to date with our quarterly newsletter, \"You've got mail.\"</p>\n                        <form class=\"flex flex-col gap-2\">\n                            <input type=\"email\" placeholder=\"Enter email address...\" class=\"bg-black/50 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:outline-none focus:border-green-500 transition-colors\">\n                            <button type=\"submit\" class=\"bg-white text-black text-sm font-bold rounded-lg px-4 py-2 hover:bg-neutral-200 transition-colors\">Subscribe</button>\n                        </form>\n                    </div>\n                </div>\n\n                <!-- Links 1 -->\n                <div>\n                    <h4 class=\"font-bold text-white mb-6\">See More</h4>\n                    <ul class=\"space-y-4 text-sm text-neutral-400 font-medium\">\n                        <li><a href=\"#home\" class=\"hover:text-green-400 transition-colors\">Home</a></li>\n                        <li><a href=\"#technology\" class=\"hover:text-green-400 transition-colors\">Technology</a></li>\n                        <li><a href=\"#products\" class=\"hover:text-green-400 transition-colors\">Products</a></li>\n                        <li><a href=\"#about\" class=\"hover:text-green-400 transition-colors\">About</a></li>\n                    </ul>\n                </div>\n\n                <!-- Links 2 -->\n                <div>\n                    <h4 class=\"font-bold text-white mb-6\">Follow Us</h4>\n                    <ul class=\"space-y-4 text-sm text-neutral-400 font-medium\">\n                        <li><a href=\"#\" class=\"hover:text-green-400 transition-colors flex items-center gap-2\"><i data-lucide=\"instagram\" class=\"w-4 h-4\"></i> Instagram</a></li>\n                        <li><a href=\"#\" class=\"hover:text-green-400 transition-colors flex items-center gap-2\"><i data-lucide=\"linkedin\" class=\"w-4 h-4\"></i> LinkedIn</a></li>\n                        <li><a href=\"#\" class=\"hover:text-green-400 transition-colors flex items-center gap-2\"><i data-lucide=\"twitter\" class=\"w-4 h-4\"></i> Twitter</a></li>\n                    </ul>\n                </div>\n\n                 <!-- Address/Contact Info Mockup -->\n                 <div>\n                    <h4 class=\"font-bold text-white mb-6\">Headquarters</h4>\n                    <p class=\"text-sm text-neutral-400 leading-relaxed mb-4\">\n                        123 Renewable Drive,<br>\n                        Tech Park, Silicon Valley,<br>\n                        California, 94025\n                    </p>\n                    <p class=\"text-sm text-neutral-400\">hello@pikag.com</p>\n                    <p class=\"text-sm text-neutral-400\">+1 (555) 123-4567</p>\n                </div>\n            </div>\n\n            <div class=\"flex flex-col md:flex-row items-center justify-between pt-8 border-t border-white/10 text-xs text-neutral-500 font-medium\">\n                <p>&copy; 2023 PikaG Energy. All Rights Reserved.</p>\n                <div class=\"flex space-x-6 mt-4 md:mt-0\">\n                    <a href=\"#\" class=\"hover:text-white transition-colors\">Sitemap</a>\n                    <a href=\"#\" class=\"hover:text-white transition-colors\">Privacy Policy</a>\n                </div>\n            </div>\n        </div>\n    </footer>\n\n    <script>\n        // Initialize Icons\n        lucide.createIcons({\n            attrs: {\n                class: \"lucide\",\n                \"stroke-width\": 1.5\n            }\n        });\n\n        // Scroll Reveal Logic\n        const observerOptions = {\n            threshold: 0.1,\n            rootMargin: \"0px 0px -40px 0px\"\n        };\n\n        const observer = new IntersectionObserver((entries) => {\n            entries.forEach(entry => {\n                if (entry.isIntersecting) {\n                    entry.target.classList.add('active');\n                    observer.unobserve(entry.target); \n                }\n            });\n        }, observerOptions);\n\n        document.querySelectorAll('.reveal').forEach(el => {\n            observer.observe(el);\n        });\n\n        // Hero Carousel Logic\n        const slides = document.querySelectorAll('.slide');\n        const dots = document.querySelectorAll('.slider-dot');\n        const titles = [\"Powering the <br>Next Generation.\", \"Industrial Scale <br>Wind Solutions.\", \"Smart Grid <br>Connectivity.\"];\n        const tags = [\"Sustainable Solar Ecosystems\", \"Clean Wind Energy\", \"Future Ready Infrastructure\"];\n        const descs = [\n            \"Designing the infrastructure for a cleaner planet. From industrial solar arrays to smart city integration.\",\n            \"Harnessing the power of the air. High-efficiency turbines designed for low-wind capability.\",\n            \"Connecting energy sources with intelligent monitoring systems for optimized consumption.\"\n        ];\n        \n        let currentSlide = 0;\n        let slideInterval;\n\n        function changeSlide(index) {\n            // Remove active class from current\n            slides[currentSlide].classList.remove('active');\n            slides[currentSlide].classList.add('inactive');\n            dots[currentSlide].classList.remove('bg-white');\n            dots[currentSlide].classList.add('bg-white/30');\n            \n            currentSlide = index;\n            if (currentSlide >= slides.length) currentSlide = 0;\n\n            // Add active class to new\n            slides[currentSlide].classList.remove('inactive');\n            slides[currentSlide].classList.add('active');\n            dots[currentSlide].classList.remove('bg-white/30');\n            dots[currentSlide].classList.add('bg-white');\n\n            // Update Text with simple animation\n            const titleEl = document.getElementById('slide-title');\n            const tagEl = document.getElementById('slide-tag');\n            const descEl = document.getElementById('slide-desc');\n\n            titleEl.style.opacity = 0;\n            descEl.style.opacity = 0;\n            \n            setTimeout(() => {\n                titleEl.innerHTML = titles[currentSlide];\n                tagEl.innerText = tags[currentSlide];\n                descEl.innerText = descs[currentSlide];\n                titleEl.style.opacity = 1;\n                descEl.style.opacity = 1;\n            }, 500);\n\n            // Reset Timer\n            clearInterval(slideInterval);\n            slideInterval = setInterval(() => changeSlide(currentSlide + 1), 5000);\n        }\n\n        // Start Auto Slide\n        slideInterval = setInterval(() => changeSlide(currentSlide + 1), 5000);\n\n    </script>\n</body>\n</html>","language":"html","username":"5a15ac46-a1db-4bad-ab87-f24533cec03b","created_at":"2025-12-25T05:57:19.914602+00:00","views":712,"image_url":"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/preview-images/shared-code-previews/renewable-energy-90-preview-1766891321344.jpeg","forks":36,"private":false,"watermark":true,"featured":true,"share_source_code":true,"user_id":"5a15ac46-a1db-4bad-ab87-f24533cec03b","category":"Web","updated_at":null,"tags":["Landing Page","Services","Technology","Brand","Dark","Gradient","Clean","Large Type","Energy","Renewable"],"description":"A modern renewable energy services landing page template for showcasing solar, wind, IoT and industrial energy solutions, ready to customize for your brand.","premium":false,"price":null,"purchase_url":null,"long_description":"**PikaG Energy** is a premium landing page template built for modern renewable and industrial energy brands.\n\n## What's included\n- Hero carousel with bold headline, dual CTAs, and glassmorphism nav\n- Technology bento grid for core architecture and durability highlights\n- Services grid for solar, robotics, IoT, storage, and industrial solutions\n- Global impact case study, milestone timeline, and FAQ section\n- Conversion-focused contact CTA, newsletter, and social/footer links\n\n## Key features\n- **Dark, gradient-rich hero with large type**\n- **Service cards** for multiple solution lines\n- **Case study & metrics** to showcase results\n- **Timeline story** for brand history and credibility\n- **FAQ + contact CTA** to drive inquiries\n\n## Primary use case\nUse this template to quickly launch a brand-forward marketing site for renewable energy, industrial automation, or smart grid service companies and adapt the copy, visuals, and CTAs to your own offering.","custom_domain":null,"favicon_light_url":null,"favicon_dark_url":null,"dns_verified":null,"dns_verified_at":null,"dns_a_record":null,"netlify_apex_exists":null,"netlify_www_exists":null,"netlify_verified_at":null,"custom_domain_added_at":null,"netlify_site_id":null,"umami_website_id":null,"umami_share_id":null,"analytics_enabled":false,"gtm_container_id":null}]